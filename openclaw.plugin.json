{
  "id": "mapick-firewall",
  "name": "Mapick Cost Firewall",
  "description": "AI call circuit breaker — block runaway requests, see who's burning money, one-click emergency stop.",
  "version": "0.2.0",
  "providers": [
    "mapick"
  ],
  "contracts": {
    "tools": [
      "firewall"
    ]
  },
  "toolMetadata": {},
  "modelSupport": {
    "modelPrefixes": [
      "mapick/"
    ]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "breaker": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "consecutiveFailures": {
            "type": "number",
            "default": 3
          },
          "cooldownSec": {
            "type": "number",
            "default": 30
          },
          "tokenVelocityWindowSec": {
            "type": "number",
            "default": 60
          },
          "tokenVelocityThreshold": {
            "type": "number",
            "default": 100000
          },
          "callFrequencyWindowSec": {
            "type": "number",
            "default": 60
          },
          "callFrequencyThreshold": {
            "type": "number",
            "default": 30
          }
        }
      },
      "dailyTokenLimit": {
        "type": [
          "number",
          "null"
        ],
        "default": null
      },
      "privacy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "storePromptText": {
            "type": "boolean",
            "default": false
          },
          "enableRawConversationHooks": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
